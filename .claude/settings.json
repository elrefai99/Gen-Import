{
  "permissions": {
    "allow": [
      "Bash(pnpm lint*)",
      "Bash(pnpm build*)",
      "Bash(pnpm test*)",
      "Bash(pnpm gen:imports*)",
      "Bash(pnpm install*)",
      "Bash(pnpm taze*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(git add src/*)"
