{
  "name": "express-app-js-example",
  "version": "1.0.0",
  "description": "Full Express + JavaScript (ESM) example showing gen-import barrel files",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "gen": "node ../../dist/cli.js --packages --app-config --exclude-pkg express",
    "gen:source": "node ../../dist/cli.js",
    "gen:packages": "node ../../dist/cli.js --packages-only --exclude-pkg express",
    "gen:all": "node ../../dist/cli.js --packages --app-config --exclude-pkg express"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "express": "^4.18.2"
  }
}
